{
  "task_type": "multi_label_classification",
  "model": {
    "name": "distilbert/distilbert-base-uncased",
    "output_dir": "distilbert-classifier"
  },
  "dataset": {
    "label_column": "label",
    "text_columns": ["text"],
    "text_perturbation": {
      "source_column": "text",
      "output_column": "text",
      "lang_column": null,
      "num_variants": 1,
      "mutation_config": {
        "keep_original": true,
        "sentence_mutation_prob": 0.25,
        "word_casing_prob": 0.2,
        "char_noise_prob": 0.15
      }
    },
    "label_transform": {
      "type": "single_to_multi_label",
      "source_column": "label",
      "output_column": "labels"
    },
    "source": {
      "type": "hf_dataset",
      "dataset_name": "rotten_tomatoes",
      "config": null,
      "split": "train"
    },
    "cache_dir": ".cache/test/tokenized",
    "split_strategy": {
      "type": "random",
      "val_size": 0.1,
      "test_size": 0.1
    },
    "seed": 42
  },
  "tokenization": {
    "kind": "text",
    "max_length": 512,
    "padding": "max_length",
    "label_columns": ["label", "labels", "binary_label", "category_labels"]
  },
  "training": {
    "num_train_epochs": 2,
    "learning_rate": 2e-5,
    "per_device_train_batch_size": 8,
    "per_device_eval_batch_size": 4,
    "gradient_accumulation_steps": 4,
    "evals_per_epoch": 2,
    "saves_per_epoch": 2,
    "logging_steps": 100,
    "weight_decay": 0.01,
    "fp16": true,
    "dataloader_num_workers": 4,
    "seed": 42,
    "threshold": 0.5,
    "metric_prefix": "binary"
  }
}
