{
  "task_type": "multi_label_classification",
  "model": {
    "name": "distilbert/distilbert-base-uncased",
    "output_dir": "distilbert-emotions"
  },
  "dataset": {
    "label_column": "label",
    "text_columns": [
      "text"
    ],
    "cache_dir": ".cache/emotions/tokenized",
    "split_strategy": {
      "type": "random",
      "val_size": 0.05,
      "test_size": 0.05
    },
    "seed": 42,
    "text_perturbation": {
      "source_column": "text",
      "output_column": "text",
      "lang_column": null,
      "num_variants": 1,
      "mutation_config": {
        "keep_original": true,
        "sentence_mutation_prob": 0.25,
        "word_casing_prob": 0.0,
        "char_noise_prob": 0.15
      }
    },
    "label_transform": {
      "type": "single_to_multi_label",
      "source_column": "label",
      "output_column": "labels",
      "reserve_fraction": 0.05,
      "same_label_pack_size": 3,
      "label_names": {
        "0": "sadness",
        "1": "joy",
        "2": "love",
        "3": "anger",
        "4": "fear",
        "5": "surprise"
      }
    },
    "sources": [
      {
        "name": "canonical",
        "canonical": true,
        "enabled": true,
        "type": "hf_dataset",
        "dataset_name": "dair-ai/emotion",
        "config": "unsplit",
        "split": "train",
        "text_column": "text",
        "label_column": "label"
      },
      {
        "name": "augmentation",
        "enabled": false,
        "type": "hf_dataset",
        "dataset_name": "some/augmentation-dataset",
        "config": "default",
        "split": "train",
        "text_column": "text",
        "label_column": "label",
        "label_aliases": {
          "sad": "sadness"
        }
      },
      {
        "name": "neutral",
        "neutral": true,
        "enabled": true,
        "type": "hf_dataset",
        "dataset_name": "cais/mmlu",
        "config": "all",
        "split": "auxiliary_train",
        "text_column": "question"
      }
    ]
  },
  "tokenization": {
    "kind": "text",
    "max_length": 512,
    "padding": "max_length"
  },
  "training": {
    "num_train_epochs": 1,
    "learning_rate": 2e-5,
    "per_device_train_batch_size": 8,
    "per_device_eval_batch_size": 4,
    "gradient_accumulation_steps": 4,
    "evals_per_epoch": 2,
    "saves_per_epoch": 2,
    "logging_steps": 100,
    "weight_decay": 0.01,
    "fp16": true,
    "dataloader_num_workers": 4,
    "seed": 42,
    "threshold": 0.5,
    "metric_prefix": "",
    "push_to_hub": true
  }
}